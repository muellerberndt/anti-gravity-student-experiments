{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Anti-gravity scorebook",
  "type": "object",
  "required": [
    "scorebook_id",
    "locked_before_force_data",
    "theory_branch",
    "canonical_scalar_claim",
    "proxy_scalar",
    "geometry",
    "feature_extraction",
    "scalar_formula",
    "causal_controls",
    "force_decision",
    "exclusions",
    "uncertainty",
    "verifier",
    "allowed_claim"
  ],
  "properties": {
    "scorebook_id": { "type": "string" },
    "locked_before_force_data": { "type": "boolean" },
    "geometry": {
      "type": "object",
      "required": ["mode", "force_axis", "zone_convention", "required_physical_inversion"]
    },
    "scalar_formula": {
      "type": "object",
      "required": [
        "self_read_gate",
        "record_stability_R_U",
        "predictive_boundary_coupling_P_U",
        "coherent_mismatch_reduction_C_U",
        "zone_score",
        "delta_S_hat",
        "output_table"
      ]
    },
    "canonical_scalar_claim": { "const": false },
    "proxy_scalar": {
      "type": "object",
      "required": ["symbol", "delta_symbol", "canonical_bridge_status", "classification_margin_only", "non_claim"]
    },
    "causal_controls": {
      "type": "object",
      "required": ["states", "live_rule", "open_loop_replay_rule", "causal_shuffle_rule", "yoked_shuffle_replay_rule", "surrogate_method", "pass_rule"]
    },
    "verifier": {
      "type": "object",
      "required": ["command", "verifier_hash", "analysis_environment_lockfile"]
    }
  },
  "additionalProperties": true
}
