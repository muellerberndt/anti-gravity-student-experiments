{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Required packet-log CSV columns",
  "type": "object",
  "required": ["required_columns"],
  "properties": {
    "required_columns": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "required_columns": [
    "timestamp_s",
    "run_id",
    "device_id",
    "geometry_mode",
    "force_axis",
    "zone_definition",
    "orientation",
    "state",
    "state_blinded_label",
    "block_id",
    "replay_source_run_id",
    "shuffle_seed",
    "drive_packet_hash",
    "drive_vector_json_sha256",
    "record_packet_hash",
    "feedback_input_hash",
    "terminal_voltage_trace_hash",
    "terminal_current_trace_hash",
    "port_id",
    "port_zone",
    "ringdown_amp",
    "ringdown_phase_deg",
    "q_estimate",
    "prediction_error",
    "shuffled_prediction_error",
    "mismatch_before",
    "mismatch_after",
    "live_update_accepted",
    "s_top",
    "s_bottom",
    "delta_s_coh",
    "scorebook_hash",
    "adc_saturation_margin_pct",
    "temperature_c",
    "battery_v",
    "pressure_hpa",
    "scalar_pass",
    "fail_reason"
  ]
}
