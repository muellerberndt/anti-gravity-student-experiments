{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Required packet-log CSV columns",
  "type": "object",
  "required": ["required_columns"],
  "properties": {
    "required_columns": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "required_columns": [
    "timestamp_s",
    "run_id",
    "device_id",
    "geometry_mode",
    "force_axis",
    "zone_definition",
    "physical_orientation_q",
    "mount_topology_id",
    "pan_position_id",
    "state",
    "blind_code",
    "block_id",
    "replay_source_run_id",
    "shuffle_seed",
    "surrogate_method",
    "drive_packet_hash",
    "proposed_packet_hash",
    "accepted_packet_hash",
    "drive_vector_json_sha256",
    "record_packet_hash",
    "controller_input_record_hash",
    "feedback_input_hash",
    "terminal_voltage_trace_hash",
    "terminal_current_trace_hash",
    "timing_hash",
    "vibration_spectrum_hash",
    "balance_mg",
    "balance_uncertainty_mg",
    "balance_valid",
    "force_calibration_id",
    "port_id",
    "port_zone",
    "ringdown_amp",
    "ringdown_phase_deg",
    "q_estimate",
    "prediction_error",
    "surrogate_prediction_error",
    "phi_before",
    "phi_after",
    "mismatch_before",
    "mismatch_after",
    "live_update_accepted",
    "R_U",
    "P_U",
    "C_U",
    "S_hat_top",
    "S_hat_bottom",
    "delta_S_hat",
    "scorebook_hash",
    "adc_saturation_margin_pct",
    "sensor_clipping_rate",
    "temperature_c",
    "dtemp_dt_c_per_s",
    "battery_v",
    "pressure_hpa",
    "scalar_pass",
    "fail_reason"
  ]
}
